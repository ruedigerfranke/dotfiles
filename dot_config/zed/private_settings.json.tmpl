// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "terminal": {
    "font_size": 11.0,
    "font_weight": 300.0
  },
  "diff_view_style": "unified",
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "auto"
      },
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    }
  },
  "context_servers": {
    "mcp-server-context7": {
      "settings": {
        "context7_api_key": "{{ onepasswordRead "op://Personal/Context7/context7_api_key" }}"
      }
    }
  },
  "icon_theme": "Catppuccin Mocha",
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "ollama",
      "model": "ministral-3:3b"
    }
  },
  "autosave": "on_focus_change",
  "theme": "Catppuccin Mocha (blue)",
  "vim_mode": true,
  "ui_font_size": 13,
  "buffer_font_family": "Operator Mono SSm",
  // "buffer_font_family": "JetBrainsMono Nerd Font",
  // "buffer_font_family": "OperatorMono Nerd Font",
  "buffer_font_size": 12.0,
  "buffer_font_weight": 300.0,
  "buffer_line_height": {
    "custom": 2
  },
  // "ui_font_family": "Operator Mono SSm Lig",
  "relative_line_numbers": "enabled",
  "when_closing_with_no_tabs": "close_window",
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph"]
    }
  },
  "vim": {
    "use_system_clipboard": "never"
  },
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false
        }
      },
      "settings": {
        "use_bundler": true
      }
    }
  },
  "tab_bar": {
    "show": false
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle"
  },
  "minimap": {
    "show": "auto"
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic"
      },
      "comment.doc": {
        "font_style": "italic"
      },
      "keyword": {
        "font_style": "italic"
      }
    }
  }
}
